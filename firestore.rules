rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is authenticated
    function isAuth() {
      return request.auth != null;
    }
    
    // Check if the user is the authorized host
    function isHost() {
      // Allow the specific host email defined in your app.js
      return isAuth() && request.auth.token.email == 'latte1332011@gmail.com';
    }

    // ══════════════════════════════════════════
    // ROOMS
    // ══════════════════════════════════════════
    match /rooms/{roomId} {
      // Anyone logged in (even guests) can read a room's details to join it
      allow read: if isAuth();
      // Only the authorized host can create, update, or delete rooms
      allow create, update, delete: if isHost();
    }

    // ══════════════════════════════════════════
    // SAMPLES
    // ══════════════════════════════════════════
    match /samples/{sampleId} {
      // Anyone logged in can read the samples in a room
      allow read: if isAuth();
      // Only the authorized host can add, edit, or remove samples
      allow create, update, delete: if isHost();
    }

    // ══════════════════════════════════════════
    // EVALUATIONS
    // ══════════════════════════════════════════
    match /evaluations/{evaluationId} {
      // Anyone logged in can read evaluations (required for the Room Summary feature)
      allow read: if isAuth();
      
      // Users can only submit an evaluation if their user ID matches the evaluatorUid field
      allow create: if isAuth() && request.resource.data.evaluatorUid == request.auth.uid;
      
      // Users can only edit or delete their own evaluations
      allow update, delete: if isAuth() && resource.data.evaluatorUid == request.auth.uid;
    }
  }
}
